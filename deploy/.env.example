# ─────────────────────────────────────────────────────────────────────────────
# PSYX FORTRESS — Environment Variables
# Copy to .env and fill in every REQUIRED value before starting the server.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
# Port the API server listens on (Nginx proxies this)
PORT=3001

# Node environment
NODE_ENV=production

# ── Database (REQUIRED) ───────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://psyx_user:yourpassword@localhost:5432/psyx

# ── Auth (REQUIRED) ───────────────────────────────────────────────────────────
# Secret used to sign JWT tokens — generate with: openssl rand -hex 64
SESSION_SECRET=change-me-to-a-long-random-string-min-32-chars

# ── Outbound SMTP (for sending email TO external domains) ────────────────────
# Leave blank to disable external send (psyx→psyx mail still works)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=PSYX Fortress <noreply@yourdomain.com>

# ── Inbound SMTP (for RECEIVING email from external senders) ─────────────────
# Port to listen on for inbound relay (Replit blocks 25; use 2525 on VPS)
SMTP_INBOUND_PORT=2525

# ── Domain ───────────────────────────────────────────────────────────────────
# Your domain — used for @psyx.com address generation
PSYX_DOMAIN=yourdomain.com

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Max requests per 15 minutes per IP (default 200)
RATE_LIMIT_MAX=200

# ── CORS ─────────────────────────────────────────────────────────────────────
# Your frontend URL (for CORS headers)
FRONTEND_URL=https://yourdomain.com
